<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>爷爷卤味</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: #000;
    color: #fff;
}

header {
    background: #111;
    padding: 15px;
    text-align: center;
    color: yellow;
    font-size: 22px;
}

.banner {
    background: url('https://via.placeholder.com/600x200') center/cover;
    height: 150px;
}

.category {
    display: flex;
    overflow-x: auto;
    padding: 10px;
}

.category div {
    background: #222;
    margin-right: 10px;
    padding: 8px 15px;
    border-radius: 20px;
    white-space: nowrap;
}

.menu {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    padding: 10px;
}

.item {
    background: #1a1a1a;
    border-radius: 10px;
    overflow: hidden;
}

.item img {
    width: 100%;
    height: 120px;
    object-fit: cover;
}

.info {
    padding: 10px;
}

.price {
    color: yellow;
}

button {
    background: red;
    color: #fff;
    border: none;
    padding: 5px 10px;
    border-radius: 5px;
    margin-top: 5px;
}
</style>
</head>

<body>

<header>🔥 爷爷卤味</header>

<div class="banner"></div>

<div class="category">
<div>鸭脖</div>
<div>鸭翅</div>
<div>鸭头</div>
<div>素菜</div>
</div>

<div class="menu">

<div class="item">
<img src="https://via.placeholder.com/300">
<div class="info">
<p>鸭脖</p>
<p class="price">3000 Ks</p>
<button>下单</button>
</div>
</div>

<div class="item">
<img src="https://via.placeholder.com/300">
<div class="info">
<p>鸭翅</p>
<p class="price">2500 Ks</p>
<button>下单</button>
</div>
</div>

</div>

</body>
</html>